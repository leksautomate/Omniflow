{
  "manifest_version": 3,
  "name": "Omniflow",
  "version": "2.2.5",
  "description": "Automate Google Flow, batch image & video generation with Veo 3.1, Nano Banana Pro, auto 4K upscale & bulk download.",
  "permissions": [
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "downloads",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://labs.google/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labs.google/fx/*/tools/flow/*",
        "https://labs.google/fx/tools/flow/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labs.google/fx/*/tools/flow/*",
        "https://labs.google/fx/tools/flow/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}